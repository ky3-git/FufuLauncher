<Page
    x:Class="FufuLauncher.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bg="using:FufuLauncher.Services.Background"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:FufuLauncher.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:FufuLauncher.ViewModels"
    x:Name="MainPageRoot"
    Background="Transparent"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CustomPanelBackgroundBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                    <AcrylicBrush
                        x:Key="IosGlassBrush"
                        FallbackColor="#CC000000"
                        TintColor="#FFFFFF"
                        TintOpacity="0.1" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="CustomPanelBackgroundBrush" Color="#D9101010" />
                    <AcrylicBrush
                        x:Key="IosGlassBrush"
                        FallbackColor="#CC000000"
                        TintColor="#000000"
                        TintOpacity="0.15" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Storyboard x:Name="EntranceStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="RootLayoutGrid"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="RootLayoutScale"
                    Storyboard.TargetProperty="ScaleX"
                    From="0.9"
                    To="1"
                    Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="RootLayoutScale"
                    Storyboard.TargetProperty="ScaleY"
                    From="0.9"
                    To="1"
                    Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <Storyboard x:Name="ExitStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="RootLayoutGrid"
                    Storyboard.TargetProperty="Opacity"
                    From="1"
                    To="0"
                    Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <helpers:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <helpers:BoolToGlyphConverter x:Key="BoolToGlyphConverter" />

            <DataTemplate x:Key="NewsItemTemplate">
                <Button
                    Margin="0,1"
                    Padding="8,2"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding ElementName=MainPageRoot, Path=OpenLinkCommand}"
                    CommandParameter="{Binding Link}"
                    CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            FontSize="13"
                            Foreground="{Binding ElementName=MainPageRoot, Path=ViewModel.GameNewsCardTextBrush}"
                            MaxLines="1"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{Binding ElementName=MainPageRoot, Path=ViewModel.GameNewsCardTextBrush}"
                            Opacity="0.5"
                            Text="{Binding Date}" />
                    </Grid>
                </Button>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <Grid
        x:Name="RootLayoutGrid"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5">
        <Grid.Transitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="40" />
            </TransitionCollection>
        </Grid.Transitions>
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootLayoutScale" ScaleX="1" ScaleY="1" />
        </Grid.RenderTransform>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                Width="360"
                Margin="24,0,0,18"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Spacing="12">

                <Grid
                    x:Name="InfoCardContainer"
                    Height="{Binding InfoCardHeight, Mode=OneWay}"
                    PointerEntered="InfoCard_PointerEntered"
                    PointerExited="InfoCard_PointerExited"
                    Translation="0,0,32"
                    Visibility="{x:Bind ViewModel.GameNewsCardVisibility, Mode=OneWay}">

                    <Grid.Shadow>
                        <ThemeShadow />
                    </Grid.Shadow>

                    <Border
                        x:Name="InfoCardSolidBg"
                        Background="Transparent"
                        CornerRadius="12"
                        Opacity="0.5" />
                    <Border
                        x:Name="InfoCardBlurBg"
                        Background="{StaticResource IosGlassBrush}"
                        CornerRadius="12"
                        Opacity="0.0" />

                    <Grid
                        x:Name="InfoCardGrid"
                        Width="360"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="155" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid
                            x:Name="BannerImageArea"
                            Grid.Row="0"
                            Margin="0"
                            Background="#20000000"
                            CornerRadius="12,12,0,0">
                            <Grid
                                x:Name="BannerViewport"
                                Background="Transparent"
                                PointerCanceled="BannerViewport_PointerCanceled"
                                PointerExited="BannerViewport_PointerCanceled"
                                PointerPressed="BannerViewport_PointerPressed"
                                PointerReleased="BannerViewport_PointerReleased">

                                <Grid
                                    x:Name="BannerCurrentLayer"
                                    IsHitTestVisible="True"
                                    Opacity="1">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="BannerCurrentTranslate" X="0" />
                                    </Grid.RenderTransform>
                                    <Image
                                        x:Name="BannerCurrentImage"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderTransformOrigin="0.5,0.5"
                                        Stretch="Fill">
                                        <Image.RenderTransform>
                                            <ScaleTransform x:Name="BannerCurrentScale" ScaleX="1" ScaleY="1" />
                                        </Image.RenderTransform>
                                    </Image>

                                    <Button
                                        Margin="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="BannerButton_Click">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                        </Button.Resources>
                                    </Button>
                                </Grid>

                                <Grid
                                    x:Name="BannerIncomingLayer"
                                    IsHitTestVisible="False"
                                    Opacity="0">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="BannerIncomingTranslate" X="0" />
                                    </Grid.RenderTransform>
                                    <Image
                                        x:Name="BannerIncomingImage"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderTransformOrigin="0.5,0.5"
                                        Stretch="Fill">
                                        <Image.RenderTransform>
                                            <ScaleTransform x:Name="BannerIncomingScale" ScaleX="1" ScaleY="1" />
                                        </Image.RenderTransform>
                                    </Image>
                                </Grid>

                                <Button
                                    x:Name="BannerPrevButton"
                                    Margin="4,0,0,0"
                                    Padding="4,4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#99000000"
                                    BorderThickness="0"
                                    Click="BannerPrev_Click"
                                    CornerRadius="4"
                                    IsHitTestVisible="False"
                                    Opacity="0">
                                    <FontIcon
                                        FontSize="10"
                                        Foreground="White"
                                        Glyph="&#xE76B;" />
                                </Button>

                                <Button
                                    x:Name="BannerNextButton"
                                    Margin="0,0,4,0"
                                    Padding="4,4"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#99000000"
                                    BorderThickness="0"
                                    Click="BannerNext_Click"
                                    CornerRadius="4"
                                    IsHitTestVisible="False"
                                    Opacity="0">
                                    <FontIcon
                                        FontSize="10"
                                        Foreground="White"
                                        Glyph="&#xE76C;" />
                                </Button>

                                <Button
                                    x:Name="InfoExpandButton"
                                    Margin="0,0,8,8"
                                    Padding="6,2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Background="#99000000"
                                    BorderThickness="0"
                                    Command="{Binding ToggleInfoCardCommand}"
                                    CornerRadius="4"
                                    IsHitTestVisible="True"
                                    Opacity="0">
                                    <FontIcon
                                        FontSize="10"
                                        Foreground="White"
                                        Glyph="{x:Bind ViewModel.InfoExpandIcon, Mode=OneWay}" />
                                </Button>
                            </Grid>
                        </Grid>

                        <Pivot
                            x:Name="InfoCardPivot"
                            Grid.Row="1"
                            Margin="2,0,2,2">
                            <Pivot.Resources>
                                <SolidColorBrush x:Key="PivotHeaderItemForeground" Color="White" />
                                <SolidColorBrush x:Key="PivotHeaderItemForegroundSelected" Color="White" />
                                <SolidColorBrush x:Key="PivotHeaderItemForegroundPointerOver" Color="#CCFFFFFF" />
                                <SolidColorBrush x:Key="PivotHeaderItemForegroundPressed" Color="#99FFFFFF" />

                                <Style TargetType="PivotHeaderItem">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Padding" Value="12,0" />
                                    <Setter Property="MinHeight" Value="32" />
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                            </Pivot.Resources>

                            <PivotItem Header="活动">
                                <ListView
                                    Padding="4,0,4,4"
                                    ItemTemplate="{StaticResource NewsItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.ActivityPosts}"
                                    SelectionMode="None" />
                            </PivotItem>

                            <PivotItem Header="公告">
                                <ListView
                                    Padding="4,0,4,4"
                                    ItemTemplate="{StaticResource NewsItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.AnnouncementPosts}"
                                    SelectionMode="None" />
                            </PivotItem>

                            <PivotItem Header="资讯">
                                <ListView
                                    Padding="4,0,4,4"
                                    ItemTemplate="{StaticResource NewsItemTemplate}"
                                    ItemsSource="{x:Bind ViewModel.InfoPosts}"
                                    SelectionMode="None" />
                            </PivotItem>
                        </Pivot>
                    </Grid>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Column="0"
                        Translation="0,0,32"
                        Visibility="{x:Bind ViewModel.CheckinCardVisibility, Mode=OneWay}">

                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>

                        <Border
                            x:Name="CheckinCardSolidBg"
                            Background="Transparent"
                            CornerRadius="8"
                            Opacity="0.5" />
                        <Border
                            x:Name="CheckinCardBlurBg"
                            Background="{StaticResource IosGlassBrush}"
                            CornerRadius="8"
                            Opacity="0.0" />

                        <Grid
                            x:Name="CheckinCardGrid"
                            Padding="12"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Opacity="0.9"
                                    Text="原神签到" />

                                <Button
                                    Grid.Column="1"
                                    Width="24"
                                    Height="24"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Click="RefreshTokenButton_Click"
                                    CornerRadius="4"
                                    ToolTipService.ToolTip="刷新Token">
                                    <FontIcon
                                        FontSize="11"
                                        Foreground="{Binding GameCheckinTextBrush, Mode=OneWay}"
                                        Glyph="&#xE72C;" />
                                </Button>
                                <Button
                                    Grid.Column="2"
                                    Width="24"
                                    Height="24"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Click="OpenCheckinSettings_Click"
                                    CornerRadius="4"
                                    ToolTipService.ToolTip="进入签到配置">
                                    <FontIcon
                                        FontSize="11"
                                        Foreground="{Binding GameCheckinTextBrush, Mode=OneWay}"
                                        Glyph="&#xE713;" />
                                </Button>
                                <Border
                                    Grid.Column="3"
                                    Width="24"
                                    Height="24"
                                    Margin="6,0,0,0"
                                    Background="#1AFFFFFF"
                                    CornerRadius="4"
                                    ToolTipService.ToolTip="{Binding CheckinStateTooltip, Mode=OneWay}">
                                    <FontIcon
                                        FontSize="12"
                                        Foreground="{Binding CheckinStateBrush, Mode=OneWay}"
                                        Glyph="{Binding CheckinStateGlyph, Mode=OneWay}" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="White"
                                        MaxLines="2"
                                        Text="{Binding CheckinStatusText}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="White"
                                        MaxLines="2"
                                        Opacity="0.6"
                                        Text="{Binding CheckinSummary}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Button
                                    Grid.Column="1"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Click="OpenCheckinCalendar_Click"
                                    CornerRadius="6"
                                    ToolTipService.ToolTip="奖励日历">
                                    <FontIcon
                                        FontSize="13"
                                        Foreground="White"
                                        Glyph="&#xE787;" />
                                </Button>
                            </Grid>

                            <Button
                                Grid.Row="2"
                                Padding="8,6"
                                HorizontalAlignment="Stretch"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Command="{Binding ExecuteCheckinCommand}"
                                Content="{Binding CheckinButtonText}"
                                CornerRadius="4"
                                Foreground="{Binding GameCheckinTextBrush, Mode=OneWay}"
                                IsEnabled="{Binding IsCheckinButtonEnabled, Mode=OneWay}" />
                        </Grid>
                    </Grid>

                    <Grid
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        Translation="0,0,32"
                        Visibility="{x:Bind ViewModel.DailyNoteCardVisibility, Mode=OneWay}">

                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>

                        <Border
                            x:Name="DailyNoteCardSolidBg"
                            Background="Transparent"
                            CornerRadius="8"
                            Opacity="0.5" />
                        <Border
                            x:Name="DailyNoteCardBlurBg"
                            Background="{StaticResource IosGlassBrush}"
                            CornerRadius="8"
                            Opacity="0.0" />

                        <Grid
                            x:Name="DailyNoteCardGrid"
                            MinWidth="140"
                            Padding="12"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Opacity="0.9"
                                    Text="原神便签" />
                                <Button
                                    Grid.Column="1"
                                    Width="24"
                                    Height="24"
                                    Padding="0"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Click="RefreshDailyNoteButton_Click"
                                    CornerRadius="4"
                                    ToolTipService.ToolTip="刷新便签">
                                    <FontIcon
                                        FontSize="11"
                                        Foreground="White"
                                        Glyph="&#xE72C;" />
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1" MinHeight="80">
                                <TextBlock
                                    x:Name="DailyNoteEmptyText"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="White"
                                    IsHitTestVisible="False"
                                    Opacity="0.8"
                                    Text="无数据" />

                                <StackPanel
                                    x:Name="DailyNoteDataPanel"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    Spacing="8">
                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Visibility="{x:Bind ViewModel.ShowResin, Mode=OneWay}">
                                        <Image
                                            Width="24"
                                            Height="24"
                                            Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-1.cd77560a.png"
                                            Stretch="Uniform" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="White"
                                                Opacity="0.7"
                                                Text="树脂" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="White">
                                                <Run Text="{x:Bind ViewModel.CurrentResin, Mode=OneWay}" />
                                                <Run Text="/" />
                                                <Run Text="{x:Bind ViewModel.MaxResin, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Visibility="{x:Bind ViewModel.ShowDailyTasks, Mode=OneWay}">
                                        <Image
                                            Width="24"
                                            Height="24"
                                            Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-3.786c15d1.png"
                                            Stretch="Uniform" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="White"
                                                Opacity="0.7"
                                                Text="每日委托" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="White">
                                                <Run Text="{x:Bind ViewModel.FinishedTaskNum, Mode=OneWay}" />
                                                <Run Text="/" />
                                                <Run Text="{x:Bind ViewModel.TotalTaskNum, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Visibility="{x:Bind ViewModel.ShowHomeCoin, Mode=OneWay}">
                                        <Image
                                            Width="24"
                                            Height="24"
                                            Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-2.e5225a21.png"
                                            Stretch="Uniform" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="White"
                                                Opacity="0.7"
                                                Text="洞天宝钱" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="White">
                                                <Run Text="{x:Bind ViewModel.CurrentHomeCoin, Mode=OneWay}" />
                                                <Run Text="/" />
                                                <Run Text="{x:Bind ViewModel.MaxHomeCoin, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Visibility="{x:Bind ViewModel.ShowExpeditions, Mode=OneWay}">
                                        <Image
                                            Width="24"
                                            Height="24"
                                            Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-4.835b640a.png"
                                            Stretch="Uniform" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="White"
                                                Opacity="0.7"
                                                Text="探索派遣" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="White">
                                                <Run Text="{x:Bind ViewModel.CurrentExpeditionNum, Mode=OneWay}" />
                                                <Run Text="/" />
                                                <Run Text="{x:Bind ViewModel.MaxExpeditionNum, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Visibility="{x:Bind ViewModel.ShowTransformer, Mode=OneWay}">
                                        <Image
                                            Width="24"
                                            Height="24"
                                            Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-5.5feb0161.png"
                                            Stretch="Uniform" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="White"
                                                Opacity="0.7"
                                                Text="参量质变仪" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{x:Bind ViewModel.TransformerRecoveryTime, Mode=OneWay}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </StackPanel>

            <TextBlock
                x:Name="CopyrightText"
                Grid.Column="1"
                Margin="0,0,32,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                FontSize="10"
                Foreground="White"
                IsHitTestVisible="True"
                Opacity="0.05"
                PointerEntered="Copyright_PointerEntered"
                PointerExited="Copyright_PointerExited"
                Text="© 2026 FufuLauncher Development Team.All Rights Reserved." />

            <Border
                Grid.Column="1"
                Width="48"
                Margin="0,32,32,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="{StaticResource IosGlassBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Translation="0,0,32">

                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>

                <StackPanel
                    Padding="0,4"
                    HorizontalAlignment="Center"
                    Orientation="Vertical"
                    Spacing="4">

                    <StackPanel.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.ThemeDictionaries>
                                <ResourceDictionary x:Key="Light">
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#26FFFFFF" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#15FFFFFF" />
                                    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="White" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                </ResourceDictionary>
                                <ResourceDictionary x:Key="Default">
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#26FFFFFF" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#15FFFFFF" />
                                    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="White" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                </ResourceDictionary>
                            </ResourceDictionary.ThemeDictionaries>
                        </ResourceDictionary>
                    </StackPanel.Resources>

                    <Button
                        Width="44"
                        Height="44"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="AnnouncementBell_Click"
                        CornerRadius="22"
                        ToolTipService.ToolTip="公告">
                        <FontIcon
                            FontSize="18"
                            Foreground="White"
                            Glyph="&#xEA8F;" />
                    </Button>

                    <Button
                        Width="44"
                        Height="44"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="22"
                        IsEnabled="{x:Bind ViewModel.IsBackgroundToggleEnabled, Mode=OneWay}"
                        ToolTipService.ToolTip="切换背景">
                        <Button.Flyout>
                            <Flyout x:Name="BackgroundFlyout" Placement="BottomEdgeAlignedRight">
                                <GridView
                                    Width="320"
                                    MaxHeight="400"
                                    IsItemClickEnabled="True"
                                    ItemClick="BackgroundGridView_ItemClick"
                                    ItemsSource="{x:Bind ViewModel.AvailableBackgrounds, Mode=OneWay}"
                                    SelectionMode="None">
                                    <GridView.ItemTemplate>
                                        <DataTemplate x:DataType="bg:BackgroundUrlInfo">
                                            <Grid
                                                Width="140"
                                                Height="80"
                                                Margin="4"
                                                CornerRadius="4">
                                                <Image Source="{x:Bind ThumbnailUrl}" Stretch="UniformToFill" />
                                                <Border
                                                    Padding="4,2"
                                                    VerticalAlignment="Bottom"
                                                    Background="Transparent">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        FontSize="10"
                                                        Foreground="White"
                                                        Text="{x:Bind TypeText}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </Flyout>
                        </Button.Flyout>
                        <FontIcon
                            FontSize="18"
                            Foreground="White"
                            Glyph="&#xE8B9;"
                            Opacity="{x:Bind GetIconOpacity(ViewModel.IsBackgroundToggleEnabled), Mode=OneWay}" />
                    </Button>

                    <Button
                        Width="44"
                        Height="44"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding OpenScreenshotFolderCommand}"
                        CornerRadius="22"
                        IsEnabled="{x:Bind ViewModel.IsLaunchButtonEnabled, Mode=OneWay}"
                        PointerEntered="ScreenshotButton_PointerEntered"
                        PointerExited="ScreenshotButton_PointerExited"
                        ToolTipService.ToolTip="截图文件夹">
                        <FontIcon
                            FontSize="18"
                            Foreground="White"
                            Glyph="&#xE8B7;" />
                    </Button>
                </StackPanel>
            </Border>

            <StackPanel
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,0,32,105"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Spacing="12">

                <Border
                    Width="240"
                    Padding="12"
                    Background="{StaticResource IosGlassBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Translation="0,0,32"
                    Visibility="{x:Bind ViewModel.WidgetCardVisibility, Mode=OneWay}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Spacing="8">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Opacity="0.9"
                            Text="小工具" />
                        <VariableSizedWrapGrid
                            ItemHeight="42"
                            ItemWidth="42"
                            MaximumRowsOrColumns="5"
                            Orientation="Horizontal">
                            <Button
                                x:Name="BtnWidgetGacha"
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnOpenGachaAnalysisClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="抽卡记录分析"
                                Visibility="{x:Bind ViewModel.WidgetGachaVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/4e65638b8b81ca7556f0fd42612d0be2_6482084243159257686.png" />
                            </Button>
                            <Button
                                x:Name="BtnWidgetAchievement"
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnOpenAchievementsClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="成就追踪"
                                Visibility="{x:Bind ViewModel.WidgetAchievementVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/b097c597c8e957e5c29ebba956be7b77_3600296528699504897.png" />
                            </Button>
                            <Button
                                x:Name="BtnWidgetInventory"
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnOpenInventoryClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="背包物品"
                                Visibility="{x:Bind ViewModel.WidgetInventoryVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/746e735b9968d0a7496393809653bf9b_3827123919585554136.png" />
                            </Button>
                            <Button
                                x:Name="BtnWidgetPlayerRole"
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnOpenPlayerRolesClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="角色练度查询"
                                Visibility="{x:Bind ViewModel.WidgetPlayerRoleVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/816696c690ea7d95d8c13e67f794c807_6317738625095616930.png" />
                            </Button>
                            <Button
                                x:Name="BtnWidgetDailyNote"
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnOpenDailyNoteClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="旅行便签"
                                Visibility="{x:Bind ViewModel.WidgetDailyNoteWindowVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/35990ccaac57819dbaf39a47db133a59_6427418972247587857.png" />
                            </Button>
                            <Button
                                x:Name="BtnWidgetVideo"
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnOpenVideoResourcesClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="视频资源库"
                                Visibility="{x:Bind ViewModel.WidgetVideoVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/6ba109a0c67067ce3f16c18147c91f03_2613518829063232490.png" />
                            </Button>
                            <Button
                                x:Name="BtnWidgetBBS"
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="BBSButton_Click"
                                CornerRadius="8"
                                ToolTipService.ToolTip="战绩信息"
                                Visibility="{x:Bind ViewModel.WidgetBBSVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/aae53df95bd8d8f437729545e3a287ab_8614980669390833989.png" />
                            </Button>

                            <Button
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnWidgetSettingsClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="增加小工具">
                                <FontIcon
                                    FontSize="14"
                                    Foreground="White"
                                    Glyph="&#xE710;" />
                            </Button>

                            <Button
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnWidgetSettingsClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="移除小工具">
                                <FontIcon
                                    FontSize="14"
                                    Foreground="White"
                                    Glyph="&#xE738;" />
                            </Button>

                            <Button
                                x:Name="WidgetEyeButton"
                                Width="36"
                                Height="36"
                                Margin="3"
                                Padding="8"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Click="OnToggleWidgetFlyoutModeClick"
                                CornerRadius="8"
                                ToolTipService.ToolTip="切换详细功能提示">
                                <FontIcon
                                    x:Name="WidgetEyeIcon"
                                    FontSize="14"
                                    Foreground="White"
                                    Glyph="&#xE890;" />
                            </Button>
                        </VariableSizedWrapGrid>
                    </StackPanel>
                </Border>

                <Border
                    Width="240"
                    Padding="12"
                    Background="{StaticResource IosGlassBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Translation="0,0,32"
                    Visibility="{x:Bind ViewModel.PresetCardVisibility, Mode=OneWay}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Opacity="0.9"
                                Text="快速预设" />
                            <Button
                                Grid.Column="1"
                                Width="24"
                                Height="24"
                                Padding="0"
                                Background="#1AFFFFFF"
                                BorderThickness="0"
                                Command="{x:Bind ViewModel.OpenPresetManagerCommand}"
                                CornerRadius="4"
                                ToolTipService.ToolTip="管理">
                                <FontIcon
                                    FontSize="11"
                                    Foreground="White"
                                    Glyph="&#xE713;" />
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.PinnedPresets, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:PresetModel">
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                        </Grid.ColumnDefinitions>
                                        <Button
                                            Grid.Column="0"
                                            Padding="12,6"
                                            HorizontalAlignment="Stretch"
                                            Background="#1AFFFFFF"
                                            BorderThickness="0"
                                            Command="{Binding ElementName=MainPageRoot, Path=ViewModel.QuickSwitchPresetCommand}"
                                            CommandParameter="{Binding}"
                                            CornerRadius="4"
                                            Foreground="White"
                                            IsEnabled="{x:Bind IsNotActive, Mode=OneWay}">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{x:Bind Name}" />
                                        </Button>
                                        <FontIcon
                                            Grid.Column="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="White"
                                            Glyph="&#xE73E;"
                                            Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock
                            Margin="0,8"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Opacity="0.6"
                            Text="未固定任何预设"
                            Visibility="{x:Bind ViewModel.IsPinnedPresetsEmpty, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,0,32,32"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="Transparent"
                BorderThickness="0"
                Command="{x:Bind ViewModel.LaunchGameCommand}"
                CornerRadius="24"
                IsEnabled="{x:Bind ViewModel.IsLaunchButtonEnabled, Mode=OneWay}"
                Translation="0,0,48">

                <Button.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            Click="SwitchToBilibili_Click"
                            Icon="Switch"
                            Text="切换到 Bilibili 服" />
                        <MenuFlyoutItem
                            Click="SwitchToOfficial_Click"
                            Icon="Switch"
                            Text="切换到 官方服务器" />
                    </MenuFlyout>
                </Button.ContextFlyout>

                <Button.Shadow>
                    <ThemeShadow />
                </Button.Shadow>

                <Grid>
                    <Border
                        Background="{StaticResource IosGlassBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="24" />

                    <Border
                        x:Name="LaunchButtonOverlayBorder"
                        Background="{x:Bind ViewModel.LaunchButtonOverlayBrush, Mode=OneWay}"
                        CornerRadius="24" />

                    <StackPanel
                        Padding="36,18"
                        Orientation="Horizontal"
                        Spacing="12">
                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind ViewModel.IsGameLaunching, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsGameLaunching, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <FontIcon
                            FontSize="20"
                            Foreground="{x:Bind ViewModel.LaunchButtonTextBrush, Mode=OneWay}"
                            Glyph="{x:Bind ViewModel.LaunchButtonIcon, Mode=OneWay}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{x:Bind ViewModel.LaunchButtonTextBrush, Mode=OneWay}"
                            Text="{x:Bind ViewModel.LaunchButtonText, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Page>
