<Page x:Class="FufuLauncher.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="using:FufuLauncher.Helpers"
      xmlns:viewModels="using:FufuLauncher.ViewModels"
      Loaded="Page_Loaded">

    <Page.Resources>
        <ResourceDictionary>
            <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
            <helpers:EnumToIntConverter x:Key="EnumToIntConverter"/>
            <helpers:LanguageEnumToBooleanConverter x:Key="LanguageEnumToBooleanConverter"/>
            <helpers:WindowModeEnumToBooleanConverter x:Key="WindowModeEnumToBooleanConverter"/>
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <helpers:StringFormatConverter x:Key="StringFormatConverter"/>
            
            <Storyboard x:Name="EntranceStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootLayoutGrid"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="ExitStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootLayoutGrid"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1" To="0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            
            <Style x:Key="PresetButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>
            
            <Style x:Key="SettingsCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="0,0,0,16"/>
            </Style>
            
            <Style x:Key="SettingItemStyle" TargetType="StackPanel">
                <Setter Property="Spacing" Value="8"/>
                <Setter Property="Margin" Value="0,12,0,0"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootLayoutGrid" Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Grid.Transitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="40"/>
            </TransitionCollection>
        </Grid.Transitions>
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootLayoutScale" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <NavigationView x:Name="SettingsNavigationView"
                        Grid.Column="0"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsPaneOpen="True"
                        SelectionChanged="SettingsNavigationView_SelectionChanged"
                        Margin="0,0,0,0"
                        Width="220"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="外观与个性化" Tag="AppearanceItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="主页文字样式" Tag="HomeTextItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE790;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="语言与区域" Tag="LanguageItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF2B7;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="游戏启动配置" Tag="LaunchConfigItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="背景与视觉效果" Tag="BackgroundItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="窗口效果" Tag="WindowEffectsItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B3;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="启动音效" Tag="StartupSoundItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D6;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="高级选项" Tag="AdvancedOptionsItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="检查更新" Tag="UpdateItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE895;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="关于" Tag="AboutItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE897;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="开发者许可认证" Tag="SecurityAuthItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72E;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
        </NavigationView>

        <ScrollViewer x:Name="SettingsScrollViewer"
                      Grid.Column="1"
                      Padding="32,32,12,24"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled"
                      ViewChanged="SettingsScrollViewer_ViewChanged">
            <StackPanel Spacing="0">
                
                <Border x:Name="AppearanceItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="外观与个性化" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
                        
                        <TextBlock Text="应用主题" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"/>
                        <TextBlock Text="选择应用程序的显示主题"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,12"/>
                        
                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <RadioButton Content="浅色模式" 
                                         FontSize="14"
                                         GroupName="AppTheme"
                                         Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                         IsChecked="{x:Bind ViewModel.ElementTheme, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light}">
                                <RadioButton.CommandParameter>
                                    <ElementTheme>Light</ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                            <RadioButton Content="深色模式" 
                                         FontSize="14"
                                         GroupName="AppTheme"
                                         Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                         IsChecked="{x:Bind ViewModel.ElementTheme, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark}">
                                <RadioButton.CommandParameter>
                                    <ElementTheme>Dark</ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                            <RadioButton Content="跟随系统设置" 
                                         FontSize="14"
                                         GroupName="AppTheme"
                                         Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                         IsChecked="{x:Bind ViewModel.ElementTheme, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Default}">
                                <RadioButton.CommandParameter>
                                    <ElementTheme>Default</ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                        </StackPanel>
                        
                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="自定义软件主题颜色" 
                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                        FontSize="14"/>
                             <TextBlock Text="选择或输入Hex颜色代码。留空并重启应用可恢复默认颜色"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Opacity="0.7"
                                        Margin="0,2,0,8"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBox Text="{x:Bind ViewModel.AppThemeColor, Mode=TwoWay}"
                                         PlaceholderText="#FFB6C1"
                                         Width="150"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="主页卡片显示" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <TextBlock Text="允许隐藏主页的游戏资讯卡片或签到卡片"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12"/>
                            
                            <ToggleSwitch Header="隐藏游戏资讯卡片"
                                          OffContent="显示"
                                          OnContent="隐藏"
                                          IsOn="{x:Bind ViewModel.IsHideGameNewsCardEnabled, Mode=TwoWay}"/>
                                          
                            <ToggleSwitch Header="隐藏签到卡片"
                                          OffContent="显示"
                                          OnContent="隐藏"
                                          IsOn="{x:Bind ViewModel.IsHideCheckinCardEnabled, Mode=TwoWay}"/>
                                          
                            <ToggleSwitch Header="隐藏便签卡片"
                                          OffContent="显示"
                                          OnContent="隐藏"
                                          IsOn="{x:Bind ViewModel.IsHideDailyNoteCardEnabled, Mode=TwoWay}"/>
                            
                            <ToggleSwitch Header="显示快速预设卡片"
                                          OffContent="隐藏"
                                          OnContent="显示"
                                          IsOn="{x:Bind ViewModel.IsShowPresetCardEnabled, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="便签卡片显示项" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <TextBlock Text="选择要在便签卡片中显示的项目，最多选择3个！"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12"/>
                            
                            <ToggleSwitch Header="显示树脂"
                                          OffContent="隐藏"
                                          OnContent="显示"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteResin, Mode=TwoWay}"/>
                                          
                            <ToggleSwitch Header="显示每日委托"
                                          OffContent="隐藏"
                                          OnContent="显示"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteDailyTasks, Mode=TwoWay}"/>
                                          
                            <ToggleSwitch Header="显示洞天宝钱"
                                          OffContent="隐藏"
                                          OnContent="显示"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteHomeCoin, Mode=TwoWay}"/>
                                          
                            <ToggleSwitch Header="显示探索派遣"
                                          OffContent="隐藏"
                                          OnContent="显示"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteExpeditions, Mode=TwoWay}"/>
                                          
                            <ToggleSwitch Header="显示参量质变仪"
                                          OffContent="隐藏"
                                          OnContent="显示"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteTransformer, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="背景遮罩透明度" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="OverlayOpacitySlider" Width="260" Minimum="0" Maximum="1" StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.GlobalBackgroundOverlayOpacity, Mode=TwoWay}"/>
                                <TextBlock Text="{Binding Value, ElementName=OverlayOpacitySlider, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:P0}'}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="Frame 背景透明度" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="FrameOpacitySlider" Width="260" Minimum="0" Maximum="1" StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.ContentFrameBackgroundOpacity, Mode=TwoWay}"/>
                                <TextBlock Text="{Binding Value, ElementName=FrameOpacitySlider, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:P0}'}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        
                        
                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="背景图片透明度" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="BgImageOpacitySlider" Width="260" Minimum="0" Maximum="1" StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.GlobalBackgroundImageOpacity, Mode=TwoWay}"/>
                                <TextBlock Text="{Binding Value, ElementName=BgImageOpacitySlider, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:P0}'}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="关闭后最小化至系统托盘" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <ToggleSwitch OffContent="已禁用"
                                          OnContent="已启用"
                                          IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}"/>
                                  
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="记住窗口大小" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <ToggleSwitch OffContent="已禁用"
                                          OnContent="已启用"
                                          IsOn="{x:Bind ViewModel.IsSaveWindowSizeEnabled, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="窗口最小大小限制" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <ToggleSwitch OffContent="已禁用"
                                          OnContent="已启用"
                                          IsOn="{x:Bind ViewModel.IsMinWindowSizeLimitEnabled, Mode=TwoWay}"/>
                        </StackPanel>
                     </StackPanel>
                 </Border>
                 
                <Border x:Name="HomeTextItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="主页文字样式" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
                        
                        <TextBlock Text="游戏资讯卡片文字颜色与透明度" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"/>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="12" Margin="0,8,0,24">
                            <TextBox Header="颜色 (Hex)" Width="120" Text="{x:Bind ViewModel.GameNewsCardTextColor, Mode=TwoWay}" PlaceholderText="#FFFFFF"/>
                            <StackPanel VerticalAlignment="Bottom">
                                <TextBlock Text="透明度" Margin="0,0,0,4"/>
                                <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.05" Value="{x:Bind ViewModel.GameNewsCardTextOpacity, Mode=TwoWay}"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="启动按钮文字颜色与透明度" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"/>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="12" Margin="0,8,0,24">
                            <TextBox Header="颜色 (Hex)" Width="120" Text="{x:Bind ViewModel.LaunchButtonTextColor, Mode=TwoWay}" PlaceholderText="#FFFFFF"/>
                            <StackPanel VerticalAlignment="Bottom">
                                <TextBlock Text="透明度" Margin="0,0,0,4"/>
                                <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.05" Value="{x:Bind ViewModel.LaunchButtonTextOpacity, Mode=TwoWay}"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="游戏签到文字颜色与透明度" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"/>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="12" Margin="0,8,0,8">
                            <TextBox Header="颜色 (Hex)" Width="120" Text="{x:Bind ViewModel.GameCheckinTextColor, Mode=TwoWay}" PlaceholderText="#FFFFFF"/>
                            <StackPanel VerticalAlignment="Bottom">
                                <TextBlock Text="透明度" Margin="0,0,0,4"/>
                                <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.05" Value="{x:Bind ViewModel.GameCheckinTextOpacity, Mode=TwoWay}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Border x:Name="LanguageItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="语言与区域" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
                        
                        <TextBlock Text="应用显示语言" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"/>
                        <TextBlock Text="重启应用后生效"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,12"/>
                        
                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <RadioButton Content="简体中文（推荐）" 
                                         FontSize="14"
                                         GroupName="AppLanguage"
                                         CommandParameter="1"
                                         IsChecked="{x:Bind ViewModel.SelectedLanguage, Converter={StaticResource LanguageEnumToBooleanConverter}, ConverterParameter=1}"
                                         Command="{x:Bind ViewModel.SwitchLanguageCommand}"/>
                            <RadioButton Content="使用系统默认语言" 
                                         FontSize="14"
                                         GroupName="AppLanguage"
                                         CommandParameter="0"
                                         IsChecked="{x:Bind ViewModel.SelectedLanguage, Converter={StaticResource LanguageEnumToBooleanConverter}, ConverterParameter=0}"
                                         Command="{x:Bind ViewModel.SwitchLanguageCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Border x:Name="LaunchConfigItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="游戏启动配置" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
                        
                        <TextBlock Text="启动窗口模式" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"/>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Spacing="12">
                            <RadioButton Content="普通窗口" 
                                         FontSize="14"
                                         GroupName="LaunchWindowMode"
                                         IsChecked="{x:Bind ViewModel.LaunchArgsWindowMode, Mode=TwoWay, Converter={StaticResource WindowModeEnumToBooleanConverter}, ConverterParameter=Normal}"/>
                            <RadioButton Content="弹出窗口（无边框）" 
                                         FontSize="14"
                                         GroupName="LaunchWindowMode"
                                         IsChecked="{x:Bind ViewModel.LaunchArgsWindowMode, Mode=TwoWay, Converter={StaticResource WindowModeEnumToBooleanConverter}, ConverterParameter=Popup}"/>
                        </StackPanel>
                        
                        <TextBlock Text="游戏分辨率" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"
                                   Margin="0,20,0,0"/>
                        <TextBlock Text="设置游戏启动时的窗口大小"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,12"/>
                        
                        <StackPanel Style="{StaticResource SettingItemStyle}" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBox Header="宽度（像素）" 
                                         Width="110"
                                         Text="{x:Bind ViewModel.LaunchArgsWidth, Mode=TwoWay}"
                                         PlaceholderText="1920"/>
                                <TextBlock Text="×" 
                                           VerticalAlignment="Bottom" 
                                           Margin="0,0,0,8" 
                                           FontSize="16"/>
                                <TextBox Header="高度（像素）" 
                                         Width="110"
                                         Text="{x:Bind ViewModel.LaunchArgsHeight, Mode=TwoWay}"
                                         PlaceholderText="1080"/>
                            </StackPanel>
                            
                            <TextBlock Text="快速预设" 
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,4,0,4"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="1280×720 (HD)" 
                                        Command="{x:Bind ViewModel.SetResolutionPresetCommand}"
                                        CommandParameter="1280 720"
                                        Style="{StaticResource PresetButtonStyle}"/>
                                <Button Content="1920×1080 (FHD)" 
                                        Command="{x:Bind ViewModel.SetResolutionPresetCommand}"
                                        CommandParameter="1920 1080"
                                        Style="{StaticResource PresetButtonStyle}"/>
                                <Button Content="2560×1440 (QHD)" 
                                        Command="{x:Bind ViewModel.SetResolutionPresetCommand}"
                                        CommandParameter="2560 1440"
                                        Style="{StaticResource PresetButtonStyle}"/>
                                <Button Content="3840×2160 (4K)" 
                                        Command="{x:Bind ViewModel.SetResolutionPresetCommand}"
                                        CommandParameter="3840 2160"
                                        Style="{StaticResource PresetButtonStyle}"/>
                                <Button Content="1440×900" 
                                        Command="{x:Bind ViewModel.SetResolutionPresetCommand}" 
                                        CommandParameter="1440 900" 
                                        Style="{StaticResource PresetButtonStyle}"/>
                                <Button Content="1920×1200" 
                                        Command="{x:Bind ViewModel.SetResolutionPresetCommand}" 
                                        CommandParameter="1920 1200" 
                                        Style="{StaticResource PresetButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,20,0,0">
                            <TextBlock Text="HDR 亮度配置" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <TextBlock Text="调整游戏内的 HDR 峰值亮度与 UI 亮度"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12"/>
                            <Button Content="打开 HDR 设置" 
                                    Click="OnOpenHDRSettingsClick"/>
                        </StackPanel>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,20,0,0">
                            <TextBlock Text="目标显示器" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"/>
                            <TextBlock Text="指定游戏启动时所在的显示器"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableMonitors, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedMonitor, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          Width="250"/>
                                <Button Content="识别显示器" 
                                        Click="OnIdentifyMonitorsClick" 
                                        Style="{StaticResource PresetButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="高级启动参数" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"
                                   Margin="0,20,0,0"/>
                        <TextBlock Text="自定义参数将追加到启动命令后"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,8"/>
                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <TextBox Header="自定义启动参数" 
                                     Text="{x:Bind ViewModel.CustomLaunchParameters, Mode=TwoWay}"
                                     PlaceholderText="例如：-fullscreen -high"
                                     MaxWidth="500"
                                     HorizontalAlignment="Left"/>
                            <InfoBar Severity="Informational"
                                     Message="提示：参数将以空格追加到游戏启动命令后，请勿输入游戏路径 如果点了没反应，请多按几下预设选项按钮"
                                     IsOpen="True"
                                     IsClosable="False"
                                     Margin="0,8,0,0"
                                     FontSize="12"/>
                        </StackPanel>
                        <TextBlock Text="自定义游戏主程序名称" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"
                                   Margin="0,20,0,0"/>
                        <TextBlock Text="修改此项可自定义检测和启动时的 exe 文件名。留空则使用默认值 (YuanShen.exe / GenshinImpact.exe)"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,8"/>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="16">
                            <TextBox Text="{x:Bind ViewModel.CustomGameExeName, Mode=TwoWay}"
                                     PlaceholderText="例如: YuanShen.exe"
                                     Width="250"
                                     VerticalAlignment="Center"/>
                            <Button Content="恢复默认"
                                    Command="{x:Bind ViewModel.ResetGameExeNameCommand}"
                                    Style="{StaticResource PresetButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Border x:Name="BackgroundItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="背景与视觉效果" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
                        
                        <ToggleSwitch Header="启用自定义背景"
                                      OffContent="已禁用"
                                      OnContent="已启用"
                                      IsOn="{x:Bind ViewModel.IsBackgroundEnabled, Mode=TwoWay}"/>
                        
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="背景来源" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>
                            <StackPanel Spacing="8">
                                <Button Content="选择自定义背景图片..." 
                                        Command="{x:Bind ViewModel.SelectCustomBackgroundCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="12,6"
                                        CornerRadius="6"/>
                                <Button Content="清除自定义背景" 
                                        Command="{x:Bind ViewModel.ClearCustomBackgroundCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="12,6"
                                        CornerRadius="6"
                                        Visibility="{x:Bind ViewModel.HasCustomBackground, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                            <Setter Property="Background" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <TextBlock Text="背景轮播模式" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"
                                       Margin="0,16,0,8"/>
                            <ToggleSwitch OffContent="已禁用"
                                          OnContent="已启用"
                                          IsOn="{x:Bind ViewModel.IsBackgroundSlideshowEnabled, Mode=TwoWay}"/>
                            <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IsBackgroundSlideshowEnabled, Mode=OneWay}">
                                <Button Content="选择轮播图片文件夹..." 
                                        Command="{x:Bind ViewModel.SelectBackgroundSlideshowFolderCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="12,6"
                                        CornerRadius="6"/>
                                <TextBlock Text="{x:Bind ViewModel.BackgroundSlideshowFolder, Mode=OneWay}" 
                                           FontSize="12" Opacity="0.7" TextWrapping="Wrap" MaxWidth="400"
                                           Visibility="{x:Bind ViewModel.HasBackgroundSlideshowFolder, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <Button Content="清除轮播图片文件夹" 
                                        Command="{x:Bind ViewModel.ClearBackgroundSlideshowFolderCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="12,6"
                                        CornerRadius="6"
                                        Visibility="{x:Bind ViewModel.HasBackgroundSlideshowFolder, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                            <Setter Property="Background" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <NumberBox Header="轮播间隔 (秒)"
                                           Value="{x:Bind ViewModel.BackgroundSlideshowInterval, Mode=TwoWay}"
                                           Minimum="1"
                                           Maximum="86400"
                                           SpinButtonPlacementMode="Inline"
                                           Width="200"
                                           HorizontalAlignment="Left"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
    
                            <ComboBox Header="官方背景服务器" 
                                      Margin="0,16,0,0" 
                                      SelectedIndex="{x:Bind ViewModel.SelectedServer, Mode=TwoWay, Converter={StaticResource EnumToIntConverter}}"
                                      MinWidth="200">
                                <ComboBoxItem Content="国服 (天空岛)"/>
                                <ComboBoxItem Content="国际服 (提瓦特)"/>
                            </ComboBox>

                            <TextBlock Text="获取官方背景资源" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14"
                                       Margin="0,16,0,8"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="下载最新背景图片" 
                                        Command="{x:Bind ViewModel.DownloadLatestBackgroundImageCommand}"
                                        Padding="12,6"
                                        CornerRadius="6"/>
                                <Button Content="下载最新背景视频" 
                                        Command="{x:Bind ViewModel.DownloadLatestBackgroundVideoCommand}"
                                        Padding="12,6"
                                        CornerRadius="6"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,16,0,0">
                            <ToggleSwitch Header="启用页面亚克力模糊遮罩"
                                          OffContent="纯色"
                                          OnContent="亚克力模糊"
                                          IsOn="{x:Bind ViewModel.IsAcrylicOverlayEnabled, Mode=TwoWay}"/>
                            <TextBlock Text="注意：当使用视频背景时，为保证性能与显示效果，将自动回退为纯色半透明背景"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Border x:Name="WindowEffectsItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="窗口效果" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
                        
                        <TextBlock Text="窗口背景材质" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"/>
                        <TextBlock Text="选择窗口背景的视觉效果"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,12"/>
                        
                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <RadioButton Content="Mica (云母)" 
                                         FontSize="14"
                                         GroupName="WindowBackdrop"
                                         IsChecked="{Binding CurrentWindowBackdrop, Mode=TwoWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Mica}">
                            </RadioButton>
                            <RadioButton Content="Acrylic (亚克力)" 
                                         FontSize="14"
                                         GroupName="WindowBackdrop"
                                         IsChecked="{Binding CurrentWindowBackdrop, Mode=TwoWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Acrylic}">
                            </RadioButton>
                        </StackPanel>
                        <InfoBar Severity="Warning"
                                 Message="注意：Mica 效果仅在 Windows 11 上可用，旧版本系统可能会回退到纯色。"
                                 IsOpen="True"
                                 IsClosable="False"
                                 Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border x:Name="StartupSoundItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="启动音效" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
                        
                        <ToggleSwitch Header="启用游戏启动音效"
                                      OffContent="已禁用"
                                      OnContent="已启用"
                                      IsOn="{x:Bind ViewModel.IsStartupSoundEnabled, Mode=TwoWay}"/>
                        
                        <StackPanel Margin="0,16,0,0" 
                                    Visibility="{x:Bind ViewModel.IsStartupSoundEnabled, Mode=OneWay}">
                            <Button Content="选择音频文件..." 
                                    Command="{x:Bind ViewModel.SelectStartupSoundCommand}"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    CornerRadius="6"/>
                            <TextBlock Text="{x:Bind ViewModel.StartupSoundPath, Mode=OneWay}" 
                                       FontSize="12" Opacity="0.7" TextWrapping="Wrap" MaxWidth="400"
                                       Margin="0,8,0,0"
                                       Visibility="{x:Bind ViewModel.HasCustomStartupSound, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Button Content="清除音频文件" 
                                    Command="{x:Bind ViewModel.ClearStartupSoundCommand}"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    CornerRadius="6"
                                    Margin="0,8,0,0"
                                    Visibility="{x:Bind ViewModel.HasCustomStartupSound, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                        <Setter Property="Background" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Border x:Name="AdvancedOptionsItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="高级选项" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
                        
                        <ToggleSwitch Header="启用 BetterGI 联动"
                                      OffContent="已禁用"
                                      OnContent="已启用"
                                      IsOn="{x:Bind ViewModel.IsBetterGIIntegrationEnabled, Mode=TwoWay}"
                                      Margin="0,16,0,0"/>
                        <TextBlock Text="启动游戏时的同时打开BetterGI"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,0,0,0"/>
                                   
                        <ToggleSwitch Header="退出游戏时关闭 BetterGI"
                                      OffContent="已禁用"
                                      OnContent="已启用"
                                      IsOn="{x:Bind ViewModel.IsBetterGICloseOnExitEnabled, Mode=TwoWay}"
                                      Margin="0,8,0,0"/>
                        <TextBlock Text="点击退出游戏,自动关闭BetterGI"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,0,0,0"/>
                        <TextBlock Text="浏览器缓存清理" Style="{ThemeResource BodyStrongTextBlockStyle}" FontSize="14" Margin="0,20,0,0"/>
                        <TextBlock Text="清理内置浏览器 (WebView2) 产生的缓存文件" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,2,0,8"/>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{x:Bind ViewModel.WebView2CacheSize, Mode=OneWay}" 
                                       VerticalAlignment="Center" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"/>
                            <Button Content="清除缓存" 
                                    Command="{x:Bind ViewModel.ClearWebView2CacheCommand}" 
                                    Style="{StaticResource PresetButtonStyle}" />
                        </StackPanel>
                        <Button HorizontalAlignment="Center"
                                Margin="0,20,0,10"
                                Padding="16,8"
                                Click="OnOpenDatabaseEditorClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="配置编辑"/>
                            </StackPanel>
                        </Button>
                        <Button HorizontalAlignment="Center"
                                Margin="0,10,0,10"
                                Padding="16,8"
                                Click="OnOpenAchievementUpdaterClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="更新成就数据库资源"/>
                            </StackPanel>
                        </Button>
                        <ToggleSwitch Header="启动时自动签到"
                                      OffContent="已禁用"
                                      OnContent="已启用"
                                      IsOn="{x:Bind ViewModel.IsAutoCheckinEnabled, Mode=TwoWay}"
                                      Margin="0,16,0,0"/>
                        <TextBlock Text="开启后，将在应用启动时自动检测并在未签到时执行一键签到"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border x:Name="UpdateItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="检查更新" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,16"/>
        
                        <TextBlock Text="版本更新" 
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14"/>
                        <TextBlock Text="检查并获取最新版本。点击后将启动更新程序"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,12"/>
        
                        <Button x:Name="CheckUpdateButton"
                                Content="检查更新" 
                                Command="{x:Bind ViewModel.CheckUpdateCommand}" 
                                HorizontalAlignment="Left" 
                                Padding="12,6" 
                                CornerRadius="6" />
                    </StackPanel>
                </Border>

                <Border x:Name="AboutItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="关于" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" 
                                CornerRadius="4"
                                Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="FufuLauncher" Style="{ThemeResource BodyTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                               Style="{ThemeResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1" 
                                        Content="关于我们" 
                                        Click="OnOpenAboutWindowClick"/>
                            </Grid>
                        </Border>
                        <Button x:Name="EasterEggButton"
                                HorizontalAlignment="Center"
                                Margin="0,30,0,30"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="OnEasterEggClick"
                                ToolTipService.ToolTip="???"> 
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEB52;" FontFamily="Segoe MDL2 Assets" Foreground="#FFB6C1"/>
                                <TextBlock Text="Remember me" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border x:Name="SecurityAuthItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="开发者许可认证" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="通过开发者许可认证获取部分特殊功能的使用权限" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                        
                        <Button Content="进行开发者许可认证" 
                                HorizontalAlignment="Left"
                                Padding="12,6"
                                CornerRadius="6"
                                Click="OnOpenSecurityAuthClick"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>