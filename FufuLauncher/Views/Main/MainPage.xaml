<Page
    x:Class="FufuLauncher.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:FufuLauncher.Helpers"
    xmlns:bg="using:FufuLauncher.Services.Background"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:FufuLauncher.ViewModels"
    x:Name="MainPageRoot"
    Background="Transparent"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CustomPanelBackgroundBrush"
                                     Color="{ThemeResource CardBackgroundFillColorDefault}"/>
                    <AcrylicBrush x:Key="IosGlassBrush" 
                                  TintColor="#FFFFFF" 
                                  TintOpacity="0.1" 
                                  FallbackColor="#CC000000"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="CustomPanelBackgroundBrush" 
                                     Color="#D9101010"/>
                    <AcrylicBrush x:Key="IosGlassBrush" 
                                  TintColor="#000000" 
                                  TintOpacity="0.15" 
                                  FallbackColor="#CC000000"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Storyboard x:Name="EntranceStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootLayoutGrid"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="RootLayoutScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 From="0.9" To="1" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="RootLayoutScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 From="0.9" To="1" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            
            <Storyboard x:Name="ExitStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootLayoutGrid"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1" To="0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <helpers:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <helpers:BoolToGlyphConverter x:Key="BoolToGlyphConverter"/>
            
            <DataTemplate x:Key="NewsItemTemplate">
                <Button Background="Transparent" BorderThickness="0" Padding="8,2" Margin="0,1"
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Left" CornerRadius="4"
                        Command="{Binding ElementName=MainPageRoot, Path=OpenLinkCommand}"
                        CommandParameter="{Binding Link}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="13" 
                                   Foreground="{Binding ElementName=MainPageRoot, Path=ViewModel.GameNewsCardTextBrush}"
                                   TextTrimming="CharacterEllipsis" MaxLines="1" 
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding Date}" FontSize="12" 
                                   Foreground="{Binding ElementName=MainPageRoot, Path=ViewModel.GameNewsCardTextBrush}" Opacity="0.5" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootLayoutGrid" Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Grid.Transitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="40"/>
            </TransitionCollection>
        </Grid.Transitions>
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootLayoutScale" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" 
                        Width="360"
                        HorizontalAlignment="Left"
                        Margin="24,0,0,18"
                        VerticalAlignment="Bottom"
                        Spacing="12">
                
                <Grid x:Name="InfoCardContainer"
                      Height="{Binding InfoCardHeight, Mode=OneWay}"
                      Translation="0,0,32"
                      Visibility="{x:Bind ViewModel.GameNewsCardVisibility, Mode=OneWay}"
                      PointerEntered="InfoCard_PointerEntered"
                      PointerExited="InfoCard_PointerExited">

                    <Grid.Shadow>
                        <ThemeShadow />
                    </Grid.Shadow>

                    <Border x:Name="InfoCardSolidBg" Background="Transparent" CornerRadius="12" Opacity="0.5"/>
                    <Border x:Name="InfoCardBlurBg" Background="{StaticResource IosGlassBrush}" CornerRadius="12" Opacity="0.0"/>

                    <Grid x:Name="InfoCardGrid"
                          CornerRadius="12"
                          BorderThickness="1"
                          Width="360"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="155"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid x:Name="BannerImageArea" Grid.Row="0" Margin="0" CornerRadius="12,12,0,0" Background="#20000000">
                            <Grid x:Name="BannerViewport"
                                  Background="Transparent"
                                  PointerPressed="BannerViewport_PointerPressed"
                                  PointerReleased="BannerViewport_PointerReleased"
                                  PointerCanceled="BannerViewport_PointerCanceled"
                                  PointerExited="BannerViewport_PointerCanceled">

                                <Grid x:Name="BannerCurrentLayer"
                                      Opacity="1"
                                      IsHitTestVisible="True">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="BannerCurrentTranslate" X="0"/>
                                    </Grid.RenderTransform>
                                    <Image x:Name="BannerCurrentImage"
                                            Stretch="Fill"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform x:Name="BannerCurrentScale" ScaleX="1" ScaleY="1"/>
                                        </Image.RenderTransform>
                                    </Image>

                                    <Button Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Margin="0"
                                            Padding="0"
                                            BorderThickness="0"
                                            Click="BannerButton_Click">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                                        </Button.Resources>
                                    </Button>
                                </Grid>

                                <Grid x:Name="BannerIncomingLayer"
                                      Opacity="0"
                                      IsHitTestVisible="False">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="BannerIncomingTranslate" X="0"/>
                                    </Grid.RenderTransform>
                                    <Image x:Name="BannerIncomingImage"
                                            Stretch="Fill"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform x:Name="BannerIncomingScale" ScaleX="1" ScaleY="1"/>
                                        </Image.RenderTransform>
                                    </Image>
                                </Grid>

                                <!-- 左箭头 -->
                                <Button x:Name="BannerPrevButton"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Margin="4,0,0,0"
                                        Background="#99000000"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Padding="4,4"
                                        Opacity="0"
                                        IsHitTestVisible="False"
                                        Click="BannerPrev_Click">
                                    <FontIcon Glyph="&#xE76B;" FontSize="10" Foreground="White"/>
                                </Button>

                                <!-- 右箭头 -->
                                <Button x:Name="BannerNextButton"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,4,0"
                                        Background="#99000000"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Padding="4,4"
                                        Opacity="0"
                                        IsHitTestVisible="False"
                                        Click="BannerNext_Click">
                                    <FontIcon Glyph="&#xE76C;" FontSize="10" Foreground="White"/>
                                </Button>

                                <Button x:Name="InfoExpandButton"
                                        VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                        Margin="0,0,8,8"
                                        Background="#99000000"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Opacity="0"
                                        IsHitTestVisible="True"
                                        Command="{Binding ToggleInfoCardCommand}">
                                    <FontIcon Glyph="{x:Bind ViewModel.InfoExpandIcon, Mode=OneWay}"
                                              FontSize="10" Foreground="White"/>
                                </Button>
                            </Grid>
                        </Grid>

                        <Pivot x:Name="InfoCardPivot" Grid.Row="1" Margin="2,0,2,2">
                            <Pivot.Resources>
                                <SolidColorBrush x:Key="PivotHeaderItemForeground" Color="White" />
                                <SolidColorBrush x:Key="PivotHeaderItemForegroundSelected" Color="White" />
                                <SolidColorBrush x:Key="PivotHeaderItemForegroundPointerOver" Color="#CCFFFFFF" />
                                <SolidColorBrush x:Key="PivotHeaderItemForegroundPressed" Color="#99FFFFFF" />
                                 
                                <Style TargetType="PivotHeaderItem">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="MinHeight" Value="32"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </Pivot.Resources>

                            <PivotItem Header="活动">
                                <ListView ItemsSource="{x:Bind ViewModel.ActivityPosts}"
                                          ItemTemplate="{StaticResource NewsItemTemplate}"
                                          SelectionMode="None"
                                          Padding="4,0,4,4">
                                </ListView>
                            </PivotItem>

                            <PivotItem Header="公告">
                                <ListView ItemsSource="{x:Bind ViewModel.AnnouncementPosts}"
                                          ItemTemplate="{StaticResource NewsItemTemplate}"
                                          SelectionMode="None"
                                          Padding="4,0,4,4">
                                </ListView>
                            </PivotItem>

                            <PivotItem Header="资讯">
                                <ListView ItemsSource="{x:Bind ViewModel.InfoPosts}"
                                          ItemTemplate="{StaticResource NewsItemTemplate}"
                                          SelectionMode="None"
                                          Padding="4,0,4,4">
                                </ListView>
                            </PivotItem>
                        </Pivot>
                    </Grid>
                </Grid>
 
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Translation="0,0,32"
                          Visibility="{x:Bind ViewModel.CheckinCardVisibility, Mode=OneWay}">
                        
                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>

                        <Border x:Name="CheckinCardSolidBg" Background="Transparent" CornerRadius="8" Opacity="0.5"/>
                        <Border x:Name="CheckinCardBlurBg" Background="{StaticResource IosGlassBrush}" CornerRadius="8" Opacity="0.0"/>

                        <Grid x:Name="CheckinCardGrid" Padding="12" CornerRadius="8" 
                              BorderThickness="1" 
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                
                                <TextBlock Grid.Column="0" Text="原神签到" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center" Opacity="0.9"/>

                                <Button Grid.Column="1" Click="RefreshTokenButton_Click" Width="24" Height="24" Margin="6,0,0,0" Padding="0" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="4" ToolTipService.ToolTip="刷新Token">
                                    <FontIcon Glyph="&#xE72C;" FontSize="11" Foreground="{Binding GameCheckinTextBrush, Mode=OneWay}"/>
                                </Button>
                                <Button Grid.Column="2" Click="OpenCheckinSettings_Click" Width="24" Height="24" Margin="6,0,0,0" Padding="0" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="4" ToolTipService.ToolTip="进入签到配置">
                                    <FontIcon Glyph="&#xE713;" FontSize="11" Foreground="{Binding GameCheckinTextBrush, Mode=OneWay}"/>
                                </Button>
                                <Border Grid.Column="3" Width="24" Height="24" Margin="6,0,0,0" Background="#1AFFFFFF" CornerRadius="4" ToolTipService.ToolTip="{Binding CheckinStateTooltip, Mode=OneWay}">
                                    <FontIcon Glyph="{Binding CheckinStateGlyph, Mode=OneWay}" FontSize="12" Foreground="{Binding CheckinStateBrush, Mode=OneWay}"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding CheckinStatusText}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" Foreground="White"/>
                                    <TextBlock Text="{Binding CheckinSummary}" FontSize="11" Foreground="White" Opacity="0.6" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2"/>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                        Click="OpenCheckinCalendar_Click" 
                                        Width="28" Height="28" 
                                        Padding="0"
                                        Background="#1AFFFFFF" 
                                        BorderThickness="0" 
                                        CornerRadius="6" 
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center" 
                                        ToolTipService.ToolTip="奖励日历">
                                    <FontIcon Glyph="&#xE787;" FontSize="13" Foreground="White"/>
                                </Button>
                            </Grid>

                            <Button Grid.Row="2" Content="{Binding CheckinButtonText}" Command="{Binding ExecuteCheckinCommand}" IsEnabled="{Binding IsCheckinButtonEnabled, Mode=OneWay}" HorizontalAlignment="Stretch" Background="#1AFFFFFF" 
                                    BorderThickness="0" Foreground="{Binding GameCheckinTextBrush, Mode=OneWay}" CornerRadius="4" Padding="8,6"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1"
                          Margin="12,0,0,0"
                          Translation="0,0,32"
                          Visibility="{x:Bind ViewModel.DailyNoteCardVisibility, Mode=OneWay}">
                        
                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>

                        <Border x:Name="DailyNoteCardSolidBg" Background="Transparent" CornerRadius="8" Opacity="0.5"/>
                        <Border x:Name="DailyNoteCardBlurBg" Background="{StaticResource IosGlassBrush}" CornerRadius="8" Opacity="0.0"/>

                        <Grid x:Name="DailyNoteCardGrid" Padding="12" CornerRadius="8" 
                              BorderThickness="1" 
                              MinWidth="140"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="原神便签" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="White" VerticalAlignment="Center" Opacity="0.9"/>
                                <Button Grid.Column="1" Click="RefreshDailyNoteButton_Click" Width="24" Height="24" Padding="0" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="4" ToolTipService.ToolTip="刷新便签">
                                    <FontIcon Glyph="&#xE72C;" FontSize="11" Foreground="White"/>
                                </Button>
                            </Grid>
                            
                            <Grid Grid.Row="1" MinHeight="80">
                                <TextBlock x:Name="DailyNoteEmptyText" 
                                           Text="无数据" 
                                           FontSize="13" 
                                           Foreground="White" 
                                           Opacity="0.8" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           IsHitTestVisible="False"/>

                                <StackPanel x:Name="DailyNoteDataPanel" Spacing="8" Opacity="0" IsHitTestVisible="False">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.ShowResin, Mode=OneWay}">
                                        <Image Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-1.cd77560a.png" 
                                               Width="24" Height="24" Stretch="Uniform"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="树脂" FontSize="11" Foreground="White" Opacity="0.7"/>
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                                <Run Text="{x:Bind ViewModel.CurrentResin, Mode=OneWay}"/>
                                                <Run Text="/"/>
                                                <Run Text="{x:Bind ViewModel.MaxResin, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.ShowDailyTasks, Mode=OneWay}">
                                        <Image Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-3.786c15d1.png" 
                                               Width="24" Height="24" Stretch="Uniform"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="每日委托" FontSize="11" Foreground="White" Opacity="0.7"/>
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                                <Run Text="{x:Bind ViewModel.FinishedTaskNum, Mode=OneWay}"/>
                                                <Run Text="/"/>
                                                <Run Text="{x:Bind ViewModel.TotalTaskNum, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.ShowHomeCoin, Mode=OneWay}">
                                        <Image Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-2.e5225a21.png" 
                                               Width="24" Height="24" Stretch="Uniform"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="洞天宝钱" FontSize="11" Foreground="White" Opacity="0.7"/>
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                                <Run Text="{x:Bind ViewModel.CurrentHomeCoin, Mode=OneWay}"/>
                                                <Run Text="/"/>
                                                <Run Text="{x:Bind ViewModel.MaxHomeCoin, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.ShowExpeditions, Mode=OneWay}">
                                        <Image Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-4.835b640a.png" 
                                               Width="24" Height="24" Stretch="Uniform"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="探索派遣" FontSize="11" Foreground="White" Opacity="0.7"/>
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                                <Run Text="{x:Bind ViewModel.CurrentExpeditionNum, Mode=OneWay}"/>
                                                <Run Text="/"/>
                                                <Run Text="{x:Bind ViewModel.MaxExpeditionNum, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.ShowTransformer, Mode=OneWay}">
                                        <Image Source="https://webstatic.mihoyo.com/app/community-game-records/images/logo-5.5feb0161.png" 
                                               Width="24" Height="24" Stretch="Uniform"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="参量质变仪" FontSize="11" Foreground="White" Opacity="0.7"/>
                                            <TextBlock Text="{x:Bind ViewModel.TransformerRecoveryTime, Mode=OneWay}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </StackPanel>
           
            <TextBlock Grid.Column="1"
                       Text="© 2026 FufuLauncher Development Team.All Rights Reserved."
                       FontSize="10"
                       Foreground="White"
                       Opacity="0.05"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Right"
                       Margin="0,0,32,10"
                       PointerEntered="Copyright_PointerEntered"
                       PointerExited="Copyright_PointerExited"
                       x:Name="CopyrightText"
                       IsHitTestVisible="True"/>
            
            <StackPanel Grid.Column="1" 
                        Orientation="Vertical" 
                        VerticalAlignment="Top" 
                        HorizontalAlignment="Right" 
                        Margin="0,32,32,0" 
                        Spacing="12">
                
                <Button Click="AnnouncementBell_Click"
                        CornerRadius="24" 
                        Padding="0" 
                        Background="Transparent" 
                        BorderThickness="0"
                        HorizontalAlignment="Right">
                    <Grid>
                        <Border Background="{StaticResource IosGlassBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" 
                                CornerRadius="24" />
                        <FontIcon Glyph="&#xEA8F;" FontSize="18" Foreground="White" Margin="14,12"/>
                    </Grid>
                </Button>
                
                <Grid Background="Transparent" 
                      HorizontalAlignment="Right">
                    <Button IsEnabled="{x:Bind ViewModel.IsBackgroundToggleEnabled, Mode=OneWay}" 
                            CornerRadius="24" 
                            Padding="0" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Margin="0">
        
                        <Button.Flyout>
                            <Flyout x:Name="BackgroundFlyout" Placement="BottomEdgeAlignedRight">
                                <GridView ItemsSource="{x:Bind ViewModel.AvailableBackgrounds, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="True"
                                          ItemClick="BackgroundGridView_ItemClick"
                                          Width="320" MaxHeight="400">
                                    <GridView.ItemTemplate>
                                        <DataTemplate x:DataType="bg:BackgroundUrlInfo">
                                            <Grid Width="140" Height="80" CornerRadius="4" Margin="4">
                                                <Image Source="{x:Bind ThumbnailUrl}" Stretch="UniformToFill"/>
                                                <Border Background="#99000000" VerticalAlignment="Bottom" Padding="4,2">
                                                    <TextBlock Text="{x:Bind TypeText}" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </Flyout>
                        </Button.Flyout>

                        <Grid>
                            <Border x:Name="BackgroundBlurBorder" Background="{StaticResource IosGlassBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="24">
                            </Border>
                            <FontIcon Glyph="&#xE8B9;" FontSize="18" 
                                      Foreground="White" 
                                      Margin="14,12" 
                                      Opacity="{x:Bind GetIconOpacity(ViewModel.IsBackgroundToggleEnabled), Mode=OneWay}"/>
                        </Grid>
                    </Button>
                </Grid>

                <Button Command="{Binding OpenScreenshotFolderCommand}"
                        IsEnabled="{Binding ViewModel.IsLaunchButtonEnabled, Mode=OneWay}"
                        HorizontalAlignment="Right"
                        CornerRadius="24" 
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        PointerEntered="ScreenshotButton_PointerEntered"
                        PointerExited="ScreenshotButton_PointerExited">
                    <Grid>
                        <Border x:Name="ScreenshotBlurBorder"
                                Background="{StaticResource IosGlassBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="24"
                                Opacity="1.0" />
                        <FontIcon Glyph="&#xE8B7;" FontSize="18" Foreground="White" Margin="14,12"/>
                    </Grid>
                </Button>
            </StackPanel>
            
            <StackPanel Grid.Row="1" Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,32,105"
                        Spacing="12">
                
                <Border Visibility="{x:Bind ViewModel.WidgetCardVisibility, Mode=OneWay}"
                        Background="{StaticResource IosGlassBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Width="240"
                        Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Spacing="8">
                        <TextBlock Text="小工具" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White" Opacity="0.9"/>
                        
                        <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="42" ItemHeight="42" MaximumRowsOrColumns="5">
                            <Button Click="OnOpenGachaAnalysisClick" Width="36" Height="36" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="8" Padding="8" Margin="3" ToolTipService.ToolTip="抽卡记录分析" Visibility="{x:Bind ViewModel.WidgetGachaVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/4e65638b8b81ca7556f0fd42612d0be2_6482084243159257686.png"/>
                            </Button>
                            <Button Click="OnOpenAchievementsClick" Width="36" Height="36" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="8" Padding="8" Margin="3" ToolTipService.ToolTip="成就追踪" Visibility="{x:Bind ViewModel.WidgetAchievementVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/b097c597c8e957e5c29ebba956be7b77_3600296528699504897.png"/>
                            </Button>
                            <Button Click="OnOpenInventoryClick" Width="36" Height="36" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="8" Padding="8" Margin="3" ToolTipService.ToolTip="背包物品" Visibility="{x:Bind ViewModel.WidgetInventoryVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/746e735b9968d0a7496393809653bf9b_3827123919585554136.png"/>
                            </Button>
                            <Button Click="OnOpenPlayerRolesClick" Width="36" Height="36" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="8" Padding="8" Margin="3" ToolTipService.ToolTip="角色练度查询" Visibility="{x:Bind ViewModel.WidgetPlayerRoleVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/816696c690ea7d95d8c13e67f794c807_6317738625095616930.png"/>
                            </Button>
                            <Button Click="OnOpenDailyNoteClick" Width="36" Height="36" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="8" Padding="8" Margin="3" ToolTipService.ToolTip="旅行便签" Visibility="{x:Bind ViewModel.WidgetDailyNoteWindowVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/35990ccaac57819dbaf39a47db133a59_6427418972247587857.png"/>
                            </Button>
                            <Button Click="OnOpenVideoResourcesClick" Width="36" Height="36" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="8" Padding="8" Margin="3" ToolTipService.ToolTip="视频资源库" Visibility="{x:Bind ViewModel.WidgetVideoVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/6ba109a0c67067ce3f16c18147c91f03_2613518829063232490.png"/>
                            </Button>
                            <Button Click="BBSButton_Click" Width="36" Height="36" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="8" Padding="8" Margin="3" ToolTipService.ToolTip="战绩信息" Visibility="{x:Bind ViewModel.WidgetBBSVisibility, Mode=OneWay}">
                                <Image Source="https://act-upload.mihoyo.com/ys-obc/2025/01/21/73740358/aae53df95bd8d8f437729545e3a287ab_8614980669390833989.png"/>
                            </Button>
                        </VariableSizedWrapGrid>
                    </StackPanel>
                </Border>
                
                <Border Visibility="{x:Bind ViewModel.PresetCardVisibility, Mode=OneWay}"
                        Background="{StaticResource IosGlassBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Width="240"
                        Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="快速预设" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White" Opacity="0.9"/>
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.OpenPresetManagerCommand}" Width="24" Height="24" Padding="0" Background="#1AFFFFFF" BorderThickness="0" CornerRadius="4" ToolTipService.ToolTip="管理">
                                <FontIcon Glyph="&#xE713;" FontSize="11" Foreground="White"/>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.PinnedPresets, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:PresetModel">
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding ElementName=MainPageRoot, Path=ViewModel.QuickSwitchPresetCommand}" CommandParameter="{Binding}" IsEnabled="{x:Bind IsNotActive, Mode=OneWay}" HorizontalAlignment="Stretch" Background="#1AFFFFFF" BorderThickness="0" Foreground="White" CornerRadius="4" Padding="12,6">
                                            <TextBlock Text="{x:Bind Name}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                        <FontIcon Grid.Column="1" Glyph="&#xE73E;" FontSize="12" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="未固定任何预设" Visibility="{x:Bind ViewModel.IsPinnedPresetsEmpty, Mode=OneWay}" Opacity="0.6" FontSize="12" HorizontalAlignment="Center" Margin="0,8" Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <Button Grid.Row="1" Grid.Column="1"
                    Command="{x:Bind ViewModel.LaunchGameCommand}"
                    IsEnabled="{x:Bind ViewModel.IsLaunchButtonEnabled, Mode=OneWay}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,32,32" 
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="24"
                    Translation="0,0,48">
                  
                <Button.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="切换到 Bilibili 服" Click="SwitchToBilibili_Click" Icon="Switch" />
                        <MenuFlyoutItem Text="切换到 官方服务器" Click="SwitchToOfficial_Click" Icon="Switch" />
                    </MenuFlyout>
                </Button.ContextFlyout>
                
                <Button.Shadow>
                    <ThemeShadow /> 
                </Button.Shadow>
                
                <Grid>
                    <Border Background="{StaticResource IosGlassBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="24"/>

                    <Border x:Name="LaunchButtonOverlayBorder" 
                            CornerRadius="24" 
                            Background="{x:Bind ViewModel.LaunchButtonOverlayBrush, Mode=OneWay}" />

                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="36,18">
                        <ProgressRing Width="20" Height="20"
                                      IsActive="{x:Bind ViewModel.IsGameLaunching, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsGameLaunching, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <FontIcon Glyph="{x:Bind ViewModel.LaunchButtonIcon, Mode=OneWay}" 
                                  FontSize="20" Foreground="{x:Bind ViewModel.LaunchButtonTextBrush, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.LaunchButtonText, Mode=OneWay}"
                                   Foreground="{x:Bind ViewModel.LaunchButtonTextBrush, Mode=OneWay}"
                                   FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Page>