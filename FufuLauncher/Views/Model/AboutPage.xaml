<Page
    x:Class="FufuLauncher.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/> 
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" x:FieldModifier="public" Background="Transparent" Grid.Row="0"/>

        <Grid Grid.Row="1" Padding="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="20" VerticalAlignment="Top">
                <Image Source="/Assets/WindowIcon.ico" Width="100" Height="100" HorizontalAlignment="Left"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="FufuLauncher" FontSize="28" FontWeight="Bold"/>
                    <TextBlock x:Name="VersionText" Text="Version ..." FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <HyperlinkButton x:Name="GetBuildFormActionsToggle" Content="从Github Actions获取构建" Padding="0" Margin="0" HorizontalAlignment="Left" Click="GetBuildFormActions"/>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel Spacing="32">

                    <StackPanel Spacing="12">
                        <TextBlock Text="贡献者名单" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="16">
                            <ItemsControl>
                                <StackPanel x:Name="ContributorsPanel" Spacing="12">
                                    <TextBlock x:Name="ContributorsLoadingText" Text="正在加载贡献者列表..." FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/FufuLauncher/FufuLauncher"/>
                        <HyperlinkButton Content="反馈问题" NavigateUri="https://github.com/FufuLauncher/FufuLauncher/issues"/>
                        <HyperlinkButton Content="官方网站" NavigateUri="https://philia093.xyz"/>
                        <HyperlinkButton Content="联系作者" Click="ContactAuthor_Click"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>