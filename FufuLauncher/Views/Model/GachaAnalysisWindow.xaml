                                                      ItemsSource="{x:Bind ViewModel.AnalysisDashboard.RecentFiveStarPities, Mode=OneWay}"
                                                      ItemTemplate="{StaticResource GachaBarTemplate}">
                                            <ItemsControl.RenderTransform>
                                                <CompositeTransform/>
                                            </ItemsControl.RenderTransform>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <views:GachaChartPanel MinSlotWidth="72" ChartHeight="174"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Padding="14" CornerRadius="8" Height="280"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <Grid RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="四星出货 Top10" FontSize="16" FontWeight="SemiBold"/>
                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  HorizontalScrollMode="Enabled"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  VerticalScrollMode="Disabled"
                                                  ZoomMode="Disabled"
                                                  Padding="0,0,12,14"
                                                  Loaded="OnChartScrollViewerLoaded"
                                                  SizeChanged="OnChartScrollViewerSizeChanged"
                                                  PointerWheelChanged="OnHorizontalScrollViewerPointerWheelChanged">
                                        <ItemsControl x:Name="FourStarTopChart"
                                                      RenderTransformOrigin="0.5,1"
                                                      ItemsSource="{x:Bind ViewModel.AnalysisDashboard.FourStarTopItems, Mode=OneWay}"
                                                      ItemTemplate="{StaticResource GachaBarTemplate}">
                                            <ItemsControl.RenderTransform>
                                                <CompositeTransform/>
                                            </ItemsControl.RenderTransform>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <views:GachaChartPanel MinSlotWidth="72" ChartHeight="174"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="1" Padding="14" CornerRadius="8" Height="280"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <Grid RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="五星垫数区间" FontSize="16" FontWeight="SemiBold"/>
                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  HorizontalScrollMode="Disabled"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  VerticalScrollMode="Disabled"
                                                  ZoomMode="Disabled"
                                                  Padding="0,0,12,14"
                                                  Loaded="OnChartScrollViewerLoaded"
                                                  SizeChanged="OnChartScrollViewerSizeChanged"
                                                  >
                                        <ItemsControl x:Name="PityBucketsChart"
                                                      RenderTransformOrigin="0.5,1"
                                                      ItemsSource="{x:Bind ViewModel.AnalysisDashboard.PityBuckets, Mode=OneWay}"
                                                      ItemTemplate="{StaticResource GachaBarTemplate}">
                                            <ItemsControl.RenderTransform>
                                                <CompositeTransform/>
                                            </ItemsControl.RenderTransform>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <views:GachaChartPanel MinSlotWidth="72" ChartHeight="174"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="3" Grid.ColumnSpan="2" Padding="14" CornerRadius="8" Height="280"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <Grid RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="月度抽卡趋势" FontSize="16" FontWeight="SemiBold"/>
                                            <TextBlock Text="全部卡池 1-5 星按月份统计"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <ScrollViewer Grid.Row="1"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      HorizontalScrollMode="Enabled"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      VerticalScrollMode="Disabled"
                                                      ZoomMode="Disabled"
                                                      Padding="0,0,12,14"
                                                      Loaded="OnChartScrollViewerLoaded"
                                                      SizeChanged="OnChartScrollViewerSizeChanged"
                                                      PointerWheelChanged="OnHorizontalScrollViewerPointerWheelChanged">
                                            <ItemsControl x:Name="MonthlyPullsChart"
                                                          RenderTransformOrigin="0.5,1"
                                                          ItemsSource="{x:Bind ViewModel.AnalysisDashboard.MonthlyPulls, Mode=OneWay}"
                                                          ItemTemplate="{StaticResource GachaBarTemplate}">
                                                <ItemsControl.RenderTransform>
                                                    <CompositeTransform/>
                                                </ItemsControl.RenderTransform>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <views:GachaChartPanel MinSlotWidth="72" ChartHeight="174"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                        </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
