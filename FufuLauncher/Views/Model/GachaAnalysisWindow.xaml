<Window
    x:Class="FufuLauncher.Views.GachaAnalysisWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:FufuLauncher.ViewModels"
    xmlns:models="using:FufuLauncher.Models"
    xmlns:views="using:FufuLauncher.Views"
    xmlns:converters="using:FufuLauncher.Converters"
    xmlns:helpers="using:FufuLauncher.Helpers"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    mc:Ignorable="d"
    Title="抽卡记录分析">
    
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <ThemeShadow x:Key="SharedShadow"/>
            
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolInverter x:Key="BoolInverter"/>
            <converters:CountToColorConverter x:Key="CountToColorConverter"/>
            <converters:TotalToPrimogemsConverter x:Key="TotalToPrimogemsConverter"/>
            <converters:EmptyCountToVisibilityConverter x:Key="CountToEmptyVisibilityConverter"/>
            <converters:PityStatusToVisibilityConverter x:Key="PityStatusToVisibilityConverter"/>
            <converters:GachaTabForegroundConverter x:Key="GachaTabForegroundConverter"/>
            <converters:GachaChartBrushConverter x:Key="GachaChartBrushConverter"/>
            <converters:GachaPieGeometryConverter x:Key="GachaPieGeometryConverter"/>

            <DataTemplate x:Key="GachaRowTemplate" x:DataType="models:GachaDisplayItem">
                <Grid Margin="0,4,0,4" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Shadow="{StaticResource SharedShadow}" Translation="0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="48" Height="48" CornerRadius="6" Background="{ThemeResource ControlFillColorDefaultBrush}">
                        <Grid>
                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                            <Image Source="{Binding ElementUrl}" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Count}" FontWeight="Bold" FontSize="14" Foreground="{Binding Count, Converter={StaticResource CountToColorConverter}}"/>
                                <TextBlock Text=" 抽" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Bottom" Margin="2,0,0,1"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="1">
                            <ProgressBar Maximum="{x:Bind PityMaximum}" Value="{x:Bind Count}" Foreground="{x:Bind ProgressBarColor}" Height="6" CornerRadius="3"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0" Spacing="8">
                                <TextBlock Text="{x:Bind Time}" FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <Border Background="{Binding PityStatusBrush}"
                                        CornerRadius="3" Padding="4,1"
                                        Visibility="{Binding PityStatus, Converter={StaticResource PityStatusToVisibilityConverter}}">
                                    <TextBlock Text="{Binding PityStatusText}" FontSize="9"
                                               Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="GachaKpiTemplate" x:DataType="models:GachaKpiItem">
                <Border Height="88" Padding="12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="32" Height="32" CornerRadius="6" Background="#1F4C9AFF">
                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="15" Foreground="#FF2F7CF6"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind Label}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind Value}" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind Hint}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="GachaBarTemplate" x:DataType="models:GachaChartPoint">
                <Grid MinWidth="72" MinHeight="174" Padding="4,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{x:Bind DisplayValue}" FontSize="10" FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                    <Grid Grid.Row="1" Margin="0,6,0,6" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Height="1" Opacity="0.45" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Top"/>
                        <Border Grid.Row="1" Height="1" Opacity="0.35" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Top"/>
                        <Border Grid.Row="2" Height="1" Opacity="0.35" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Top"/>
                        <Border Grid.Row="3" Height="1" Opacity="0.35" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Top"/>
                        <Border Grid.RowSpan="4"
                                Width="{x:Bind BarWidth}"
                                Height="{x:Bind BarHeight}"
                                CornerRadius="5,5,2,2"
                                Background="{Binding ColorIndex, Converter={StaticResource GachaChartBrushConverter}}"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"/>
                        <Border Grid.RowSpan="4" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Bottom"/>
                    </Grid>
                    <TextBlock Grid.Row="2" Text="{x:Bind Label}" FontSize="10" TextAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Row="3" Text="{x:Bind SubLabel}" FontSize="9" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="GachaPieSliceTemplate" x:DataType="models:GachaPieSlice">
                <Path Data="{Binding Converter={StaticResource GachaPieGeometryConverter}}" Fill="{Binding ColorIndex, Converter={StaticResource GachaChartBrushConverter}}" Stroke="{ThemeResource CardBackgroundFillColorDefaultBrush}" StrokeThickness="2"/>
            </DataTemplate>

            <DataTemplate x:Key="GachaPieLegendTemplate" x:DataType="models:GachaPieSlice">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="10" Height="10" CornerRadius="5" Background="{Binding ColorIndex, Converter={StaticResource GachaChartBrushConverter}}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{x:Bind Label}" Margin="8,0,8,0" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{x:Bind DisplayValue}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                </Grid>
            </DataTemplate>
            
        </Grid.Resources>

<Grid Height="56" HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Pivot Grid.Column="1"
                   x:Name="GachaTabPivot"
                   Width="288"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Height="56"
                   SelectionChanged="OnGachaTabPivotSelectionChanged">
                <Pivot.Resources>
                    <Style TargetType="PivotHeaderItem">
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="MinHeight" Value="48"/>
                        <Setter Property="Width" Value="144"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Pivot.Resources>
                <PivotItem>
                    <PivotItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D2;" FontSize="15"/>
                            <TextBlock Text="祈愿总览"/>
                        </StackPanel>
                    </PivotItem.Header>
                </PivotItem>
                <PivotItem>
                    <PivotItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D9;" FontSize="15"/>
                            <TextBlock Text="祈愿分析"/>
                        </StackPanel>
                    </PivotItem.Header>
                </PivotItem>
            </Pivot>

            <Button Grid.Column="2" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center" 
                    Margin="0,0,160,0" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Click="OnAboutButtonClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE946;" FontSize="14"/>
                    <TextBlock Text="关于"/>
                </StackPanel>
            </Button>
        </Grid>
        
        <Grid Margin="24,64,24,12">
            <ProgressRing x:Name="LoadingRing" HorizontalAlignment="Center" VerticalAlignment="Center" Width="40" Height="40"
                          IsActive="{Binding ViewModel.IsDataLoaded, Converter={StaticResource BoolInverter}}"/>

            <StackPanel x:Name="EmptyStatePanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24"
                        Visibility="Collapsed">
                <StackPanel.Transitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="40"/>
                    </TransitionCollection>
                </StackPanel.Transitions>
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE9D2;" FontSize="48" HorizontalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <TextBlock Text="获取抽卡记录" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="选择一种方式导入你的祈愿记录，开始分析你的抽卡数据" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                    <Button Click="OnMiYouSheLoginClick" HorizontalAlignment="Stretch" Padding="0" Shadow="{StaticResource SharedShadow}" Translation="0,0,8">
                        <Grid Width="220" Height="160" Padding="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <FontIcon Glyph="&#xE77B;" FontSize="32" HorizontalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="通过米游社账号获取" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="通过当前登录的米游社&#x0a;账号直接获取记录" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Row="2" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="8,2" HorizontalAlignment="Center">
                                <TextBlock Text="推荐" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Click="OnUrlFetchClick" HorizontalAlignment="Stretch" Padding="0" Shadow="{StaticResource SharedShadow}" Translation="0,0,8">
                        <Grid Width="220" Height="160" Padding="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <FontIcon Glyph="&#xE71B;" FontSize="32" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="通过 URL 获取" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="粘贴抽卡分析链接&#x0a;从 API 拉取记录" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Command="{x:Bind ViewModel.ImportUigfCommand}" HorizontalAlignment="Stretch" Padding="0" Shadow="{StaticResource SharedShadow}" Translation="0,0,8">
                        <Grid Width="220" Height="160" Padding="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <FontIcon Glyph="&#xE8B5;" FontSize="32" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="导入 UIGF 文件" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="从标准UIGF格式&#x0a;JSON文件导入记录&#x0a;UIGF v4.x/3.0/2.x" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>

                <StackPanel x:Name="EmptyStateStatusPanel" Spacing="8" HorizontalAlignment="Center"
                            Visibility="{Binding ViewModel.IsFetching, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar IsIndeterminate="True" Width="500"/>
                    <TextBlock x:Name="EmptyStateStatusText" Text="{x:Bind ViewModel.CrawlerStatus, Mode=OneWay}" Width="500"
                               HorizontalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <Grid Visibility="{Binding ViewModel.HasGachaData, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Name="UidComboBox"
                                  ItemsSource="{x:Bind ViewModel.UidComboItems}"
                                  SelectedItem="{x:Bind ViewModel.SelectedUid, Mode=TwoWay}"
                                  Width="150"
                                  IsEnabled="{Binding ViewModel.IsFetching, Converter={StaticResource BoolInverter}}"
                                  SelectionChanged="OnUidComboBoxSelectionChanged"/>
                        <Button IsEnabled="{Binding ViewModel.IsFetching, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock Text="更新数据"/>
                                <FontIcon Glyph="&#xE70D;" FontSize="10" Margin="2,0,0,0"/>
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="通过米游社账号获取" Click="OnMiYouSheLoginClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE77B;" FontSize="14"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="通过 URL 获取" Click="OnUrlFetchClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="导入 UIGF 文件" Command="{x:Bind ViewModel.ImportUigfCommand}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8B5;" FontSize="14"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <DropDownButton IsEnabled="{Binding ViewModel.IsFetching, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                                <TextBlock Text="导出 UIGF"/>
                            </StackPanel>
                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="导出为 v4.2" Command="{x:Bind ViewModel.ExportUigfCommand}" CommandParameter="v4.2"/>
                                    <MenuFlyoutItem Text="导出为 v4.1" Command="{x:Bind ViewModel.ExportUigfCommand}" CommandParameter="v4.1"/>
                                    <MenuFlyoutItem Text="导出为 v4.0" Command="{x:Bind ViewModel.ExportUigfCommand}" CommandParameter="v4.0"/>
                                    <MenuFlyoutItem Text="导出为 v3.0" Command="{x:Bind ViewModel.ExportUigfCommand}" CommandParameter="v3.0"/>
                                    <MenuFlyoutItem Text="导出为 v2.4" Command="{x:Bind ViewModel.ExportUigfCommand}" CommandParameter="v2.4"/>
                                    <MenuFlyoutItem Text="导出为 v2.3" Command="{x:Bind ViewModel.ExportUigfCommand}" CommandParameter="v2.3"/>
                                    <MenuFlyoutItem Text="导出为 v2.2" Command="{x:Bind ViewModel.ExportUigfCommand}" CommandParameter="v2.2"/>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <Button Command="{x:Bind ViewModel.PreFetchMetadataCommand}"
                                IsEnabled="{Binding ViewModel.IsScraping, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B9;" FontSize="14"/>
                                <TextBlock Text="预下载图片"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnDeleteGachaDataClick"
                                IsEnabled="{Binding ViewModel.IsFetching, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                <TextBlock Text="删除记录"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4" Margin="16,0,0,0" VerticalAlignment="Bottom">
                        <Grid>
                            <ProgressBar IsIndeterminate="True" HorizontalAlignment="Stretch" Visibility="{Binding ViewModel.IsFetching, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <ProgressBar IsIndeterminate="True" HorizontalAlignment="Stretch" Visibility="{Binding ViewModel.IsScraping, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.CrawlerStatus, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Enabled"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalScrollMode="Disabled"
                              PointerWheelChanged="OnHorizontalScrollViewerPointerWheelChanged"
                              Padding="0,0,18,16"
                              Visibility="{Binding ViewModel.IsOverviewSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer.Transitions>
                        <TransitionCollection>
                            <EntranceThemeTransition FromVerticalOffset="12"/>
                        </TransitionCollection>
                    </ScrollViewer.Transitions>
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        
                        <Border Width="340" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Shadow="{StaticResource SharedShadow}" Translation="0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Padding="16" Spacing="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8,8,0,0">
                                    <TextBlock Text="角色活动" FontSize="20" FontWeight="Bold"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind ViewModel.CharacterStats.TotalCount, Mode=OneWay}" FontSize="24" FontWeight="Bold"/>
                                            <TextBlock Text="总抽数" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding ViewModel.CharacterStats.TotalCount, Converter={StaticResource TotalToPrimogemsConverter}}" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                            <TextBlock Text="耗费原石数" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock FontSize="13"><Run Text="五星已垫: "/><Run Text="{x:Bind ViewModel.CharacterStats.CurrentPity, Mode=OneWay}" FontWeight="Bold" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/></TextBlock>
                                        <TextBlock FontSize="13"><Run Text="四星已垫: "/><Run Text="{x:Bind ViewModel.CharacterStats.CurrentPity4, Mode=OneWay}" FontWeight="Bold"/></TextBlock>
                                    </StackPanel>
                                    
                                    <ToggleButton Content="显示四星记录" IsChecked="{x:Bind ViewModel.IsCharacterFourStarVisible, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,12,24,12">
                                    <Grid>
                                        <StackPanel Spacing="4">
                                            <ItemsControl ItemsSource="{x:Bind ViewModel.CharacterFiveStars, Mode=OneWay}" ItemTemplate="{StaticResource GachaRowTemplate}"/>
                                            <Grid Margin="0,8" Visibility="{Binding ViewModel.ShowCharacterFourDivider, Mode=OneWay}">
                                                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Center"/>
                                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12,2" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="4">
                                                    <TextBlock Text="四星" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                            </Grid>
                                            <ItemsControl ItemsSource="{x:Bind ViewModel.CharacterFourStars, Mode=OneWay}" ItemTemplate="{StaticResource GachaRowTemplate}"
                                                          Visibility="{Binding ViewModel.IsCharacterFourStarVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"
                                                  Visibility="{Binding ViewModel.ShowCharacterNoRecords, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE9D2;" FontSize="32" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text="暂无记录" FontSize="13" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Width="340" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Shadow="{StaticResource SharedShadow}" Translation="0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Padding="16" Spacing="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8,8,0,0">
                                    <TextBlock Text="武器活动" FontSize="20" FontWeight="Bold"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind ViewModel.WeaponStats.TotalCount, Mode=OneWay}" FontSize="24" FontWeight="Bold"/>
                                            <TextBlock Text="总抽数" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding ViewModel.WeaponStats.TotalCount, Converter={StaticResource TotalToPrimogemsConverter}}" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                            <TextBlock Text="耗费原石数" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock FontSize="13"><Run Text="五星已垫: "/><Run Text="{x:Bind ViewModel.WeaponStats.CurrentPity, Mode=OneWay}" FontWeight="Bold" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/></TextBlock>
                                        <TextBlock FontSize="13"><Run Text="四星已垫: "/><Run Text="{x:Bind ViewModel.WeaponStats.CurrentPity4, Mode=OneWay}" FontWeight="Bold"/></TextBlock>
                                    </StackPanel>
                                    
                                    <ToggleButton Content="显示四星记录" IsChecked="{x:Bind ViewModel.IsWeaponFourStarVisible, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
