<Page
    x:Class="FufuLauncher.Views.AdvancedServerSwitchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="32,48,32,32">
        <StackPanel VerticalAlignment="Center" Spacing="24">
            <FontIcon Glyph="&#xE8AB;" FontSize="48" Opacity="0.8"/>
            <TextBlock Text="服务器的转换" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="注意，游戏启动时切换无效！" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
            <Button x:Name="StartBtn" Content="一键转换" Width="200" Height="40" HorizontalAlignment="Center" Click="StartBtn_Click"/>
            <Button x:Name="AlternativeStartBtn" Content="切换失败？选择另一个方法" Width="200" Height="40" HorizontalAlignment="Center" Click="AlternativeStartBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>